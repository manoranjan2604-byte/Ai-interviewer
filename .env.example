# Copy to .env for local dev. On Render, set these as environment
# variables in the dashboard instead (render.yaml already lists which
# ones are marked "sync: false" and need a value from you).

# --- Flask ---
SECRET_KEY=change-me-to-a-random-value
FLASK_DEBUG=false
HOST=0.0.0.0
PORT=5000
CORS_ORIGINS=*

# --- Meeting BaaS (Google Meet join + audio streaming) ---
MEETINGBAAS_API_KEY=
# Local dev: your ngrok URL, e.g. https://abcd1234.ngrok-free.dev
# Render: your service URL, e.g. https://your-app.onrender.com
PUBLIC_BASE_URL=
MEETINGBAAS_WAITING_ROOM_TIMEOUT=600

# --- LLM provider ---
LLM_PROVIDER=cerebras
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
LLM_FALLBACK_PROVIDER=groq
GROQ_API_KEY=

# --- Speech-to-text ---
# groq (recommended for Render: fast, no ffmpeg/PyTorch needed)
# whisper (local, needs ffmpeg + openai-whisper, CPU-heavy)
STT_PROVIDER=groq
WHISPER_MODEL=base

# --- Text-to-speech ---
# edge (recommended for Render: no system dependency, better voice)
# local (needs espeak on Linux)
TTS_PROVIDER=edge

# --- Email (report delivery) ---
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=manoranjan042007@gmail.com
SMTP_PASSWORD=uwag zkzo wowc ixqo
EMAIL_FROM=manoranjan042007@gmail.com
SMTP_USE_TLS=true



# --- Interview behavior ---
MIN_QUESTIONS=12
MAX_QUESTIONS=50
MAX_SESSIONS=20
MAX_ANSWER_SECONDS=60

# --- Rate limiting ---
RATE_LIMIT=30/minute

# --- Startup validation ---
STARTUP_VALIDATION_STRICT=true
